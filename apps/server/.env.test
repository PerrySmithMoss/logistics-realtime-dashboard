NODE_ENV=test
HOST=127.0.0.1
PORT=4000
MIN_LOG_LEVEL=INFO
INTERNAL_AUTH_SECRET=test-internal-key
ENABLE_FLEET_SIMULATOR=true
OPEN_ROUTE_SERVICE_API_KEY=test-key
SIMULATOR_TICK_INTERVAL=200
SIMULATOR_WATCHDOG_TIMEOUT=30000
FLEET_BATCH_INTERVAL_MS=50
FLEET_HYDRATION_TIMEOUT=1000
FLEET_SSE_MAX_CONCURRENT=3
FLEET_SSE_MIN_RETRY_MS=100
FLEET_SSE_HEARTBEAT_INTERVAL_MS=250

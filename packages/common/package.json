{
  "name": "@fleet/common",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=24.14.0",
    "pnpm": ">=10.33.0"
  },
  "exports": {
    ".": {
      "types": "./src/index.d.mts",
      "development": "./src/index.ts",
      "default": "./dist/index.mjs"
    },
    "./errors": {
      "types": "./src/errors/index.d.mts",
      "development": "./src/errors/index.ts",
      "default": "./dist/errors/index.mjs"
    },
    "./types": {
      "types": "./src/types/index.d.mts",
      "development": "./src/types/index.ts",
      "default": "./dist/types/index.mjs"
    },
    "./utils": {
      "types": "./src/utils/index.d.mts",
      "development": "./src/utils/index.ts",
      "default": "./dist/utils/index.mjs"
    }
  },
  "scripts": {
    "build": "tsdown",
    "clean": "rm -rf dist",
    "lint": "eslint src",
    "type-check": "tsc --noEmit",
    "type-check:test": "tsc -p tsconfig.test.json --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run src/",
    "test:int": "vitest run tests/integration",
    "test:e2e": "vitest run tests/e2e",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.1",
    "vitest": "^4.1.2",
    "tsdown": "^0.21.9"
  }
}

NODE_ENV=development
PORT=5500
HOST=localhost
MIN_LOG_LEVEL=DEBUG

ENABLE_FLEET_SIMULATOR=false

# Get a free API key at: https://openrouteservice.org/dev/#/signup
OPEN_ROUTE_SERVICE_API_KEY=your_api_key_here

SIMULATOR_TICK_INTERVAL=2000
SIMULATOR_WATCHDOG_TIMEOUT=30000
FLEET_BATCH_INTERVAL_MS=1000
FLEET_HYDRATION_TIMEOUT=30000
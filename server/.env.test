NODE_ENV=test
HOST=127.0.0.1
PORT=0
MIN_LOG_LEVEL=ERROR
INTERNAL_AUTH_SECRET=integration-test-secret
ENABLE_FLEET_SIMULATOR=true
OPEN_ROUTE_SERVICE_API_KEY=test-key
SIMULATOR_TICK_INTERVAL=200

{
  "name": "server",
  "version": "1.0.0",
  "description": "",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx --watch $([ -f .env.local ] && echo '--env-file=.env.local') ./src/index.ts",
    "build": "rm -rf dist && npm run type-check && esbuild src/index.ts --bundle --platform=node --target=node24 --sourcemap --outdir=dist --external:express",
    "start": "node --enable-source-maps ./dist/index.js",
    "start:prod-local": "node --enable-source-maps --env-file=.env ./dist/index.js",
    "lint": "eslint 'src/**/*.ts'",
    "type-check": "tsc -p tsconfig.app.json --noEmit",
    "type-check:test": "tsc -p tsconfig.test.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "express": "^5.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@fast-check/vitest": "^0.4.0",
    "@types/express": "^5.0.6",
    "esbuild": "^0.28.0",
    "eslint": "^10.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs"
}
